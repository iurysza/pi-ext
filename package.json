{
  "name": "pi-ext",
  "version": "0.1.0",
  "dependencies": {
    "@benvargas/pi-claude-code-use": "^1.0.1",
    "@mariozechner/pi-ai": "^0.69.0",
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "@mariozechner/pi-tui": "^0.69.0",
    "@sting8k/pi-vcc": "^0.3.5",
    "@tintinweb/pi-tasks": "^0.4.2",
    "better-sqlite3": "^12.10.0",
    "pi-taskflow": "^0.1.5",
    "pi-token-tank": "github:iurysza/pi-token-tank#438877f",
    "typebox": "^1.1.32"
  },
  "optionalDependencies": {
    "@ataraxy-labs/sem": "^0.3.21"
  },
  "allowScripts": {
    "@ataraxy-labs/sem@0.3.21": true,
    "@google/genai@1.52.0": true,
    "better-sqlite3@12.11.1": true,
    "koffi@2.15.2": true,
    "protobufjs@7.5.4": true,
    "protobufjs@7.6.4": true
  },
  "description": "Personal collection of Pi extensions, themes, and skills.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "license": "MIT",
  "scripts": {
    "sem:evaluate": "node extensions/pi-sem/bin/sem-eval.mjs",
    "test": "npm run test:pi-sem",
    "test:pi-sem": "node --test extensions/pi-sem/core.test.mjs extensions/review/sem-guidance.test.mjs",
    "flows:install": "mkdir -p ~/.pi/agent/taskflows && cp .pi/taskflows/*.json ~/.pi/agent/taskflows/ && ls ~/.pi/agent/taskflows/"
  },
  "pi": {
    "extensions": [
      "./extensions/custom-footer/custom-footer.ts",
      "./extensions/token-tank/index.ts",
      "./extensions/review/review.ts",
      "./extensions/leader-key/index.ts",
      "./extensions/permissions/permissions.ts",
      "./extensions/session-query/session-query.ts",
      "./extensions/ask-user-question/index.ts",
      "./extensions/tool-pills/index.ts",
      "./extensions/split-fork/index.ts",
      "./extensions/superconductor/index.ts",
      "./extensions/session-store/index.ts",
      "./extensions/cmux/index.ts",
      "./extensions/handoff/index.ts",
      "./extensions/session-snap/index.ts",
      "./extensions/pi-telescope/index.ts",
      "./extensions/pi-sem/index.ts"
    ],
    "skills": [
      "./skills/commit",
      "./skills/github",
      "./skills/visit-webpage",
      "./skills/web-search",
      "./skills/session-query",
      "./skills/sem",
      "./skills/pr-review-comments"
    ],
    "themes": [
      "./themes"
    ]
  },
  "private": true
}
